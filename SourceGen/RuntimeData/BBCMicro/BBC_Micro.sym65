soundChannel3BufferEndIndex                @ $02E8     ; }
speechBufferEmptyEndIndex                  @ $02E9     ; }

tapeInputCurrentBlockSizeLow               @ $02EA     ;
tapeInputCurrentBlockSizeHigh              @ $02EB     ;

blockFlagOfCurrentlyResidentBlock          @ $02EC     ; bit 0 = *RUN only
